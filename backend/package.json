{
  "name": "gigachat-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,worker -c blue,yellow \"npm:dev:web\" \"npm:dev:worker\"",
    "dev:web": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker/worker.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bullmq": "^5.77.1",
    "express": "^5.1.0",
    "ioredis": "^5.10.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
